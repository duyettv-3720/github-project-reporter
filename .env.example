# GitHub personal access token with read access to the project
# (classic token needs `read:project` and `repo`; fine-grained needs Projects: Read-only)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# The node ID of the GitHub ProjectV2 (starts with "PVT_...")
# Get it via: gh api graphql -f query='{ viewer { projectV2(number: 1) { id } } }'
PROJECT_ID=PVT_xxxxxxxxxxxx

# Slack Incoming Webhook URL for the target channel (optional).
# If omitted, the script prints the report to the console (dry-run) instead of posting.
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# --- Additional projects (multi-project) ---
# Each project in script/config.js (PROJECTS) references an env var name for its
# Project ID and its Slack webhook. Add a matching pair per extra project, e.g.:
# PROJECT_ID_B=PVT_yyyyyyyyyyyy
# SLACK_WEBHOOK_URL_B=https://hooks.slack.com/services/aaa/bbb/ccc
# PROJECT_ID_C=PVT_zzzzzzzzzzzz
# SLACK_WEBHOOK_URL_C=https://hooks.slack.com/services/ddd/eee/fff
